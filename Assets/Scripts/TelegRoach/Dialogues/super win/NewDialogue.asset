  messages:
  - sender: 0
    text: "\u0414\u0410\u0410\u0410, \u041C\u0410\u041B\u042B\u0428\r\n\u0432\u043E\u0442
      \u044D\u0442\u043E \u0437\u0430\u0431\u0435\u0433!"
    delayAfter: 0
  - sender: 1
    text: "\u0431\u043E\u0441\u0441, \u0442\u044B \u0447\u0435\u0433\u043E \u0440\u0430\u0441\u043A\u0440\u0438\u0447\u0430\u043B\u0441\u044F"
    delayAfter: 0
  - sender: 0
    text: "\u0430 \u0442\u044B \u0447\u0435\u0433\u043E \u043C\u043E\u043B\u0447\u0438\u0448\u044C?\r\n\u0432\u0438\u0434\u0435\u043B,
      \u043A\u0430\u043A \u043E\u043D \u0438\u0445 \u0443\u0434\u0435\u043B\u0430\u043B?"
    delayAfter: 0
  - sender: 1
    text: "\u0432\u0438\u0434\u0435\u043B\r\n\u0434\u0430\u0436\u0435 \u044F \u0442\u0430\u043A\u043E\u0433\u043E
      \u043D\u0435 \u043E\u0436\u0438\u0434\u0430\u043B"
    delayAfter: 0
  - sender: 2
    text: "\u043E\u0433\u043E\u043D\u044C"
    delayAfter: 2
  - sender: 0
    text: "\u0432\u0441\u0451, \u0441 \u043C\u0435\u043D\u044F \u0431\u043E\u043D\u0443\u0441\r\n100
