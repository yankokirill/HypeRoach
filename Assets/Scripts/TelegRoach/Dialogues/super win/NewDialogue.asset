  - sender: 1
    text: "\u0430 \u0441 \u043C\u0435\u043D\u044F \u0441\u043A\u0438\u0434\u043A\u0430
      \u043D\u0430 \u043A\u0440\u043E\u0448\u043A\u0438\r\n30%"
