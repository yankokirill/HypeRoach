  m_Script: {fileID: 11500000, guid: bd89ac3767350f0468390e0322785532, type: 3}
  m_Name: NewDialogue 2
  m_EditorClassIdentifier: 
  messages:
  - sender: 0
    text: "\u0441\u043B\u0443\u0448\u0430\u0439...\r\n\u044D\u0442\u043E \u0431\u044B\u043B\u043E
      \u043D\u0435\u0447\u0442\u043E"
    delayAfter: 0
  - sender: 1
    text: "\u044F \u0442\u0430\u043A\u043E\u0433\u043E \u043D\u0435 \u0432\u0438\u0434\u0435\u043B
      \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D \u041A\u043E\u0441\u043E\u0433\u043E"
    delayAfter: 0
  - sender: 0
    text: "\u043A\u043E\u0441\u043E\u0439 \u0431\u0435\u0433\u0430\u043B \u0431\u044B\u0441\u0442\u0440\u043E,
      \u0434\u0430\r\n\u043F\u043E\u043A\u0430 \u043D\u0435 \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B
      \u043D\u0430 \u0438\u0433\u043E\u043B\u043A\u0443"
    delayAfter: 0
  - sender: 2
    text: "\u044F \u0434\u0435\u0440\u0436\u0430\u043B \u0434\u043B\u044F \u043A\u043E\u0441\u043E\u0433\u043E
      \u0441\u0432\u0435\u0447\u043A\u0443\r\n\u043E\u043D \u0431\u0435\u0436\u0430\u043B,
      \u043A\u0430\u043A \u0431\u043E\u0433\r\n\u043F\u043E\u043A\u0430 \u043D\u0435
      \u0443\u043F\u0430\u043B"
    delayAfter: 4
  - sender: 0
    text: "\u043A\u043E\u0440\u043E\u0447\u0435, \u0447\u0435\u043C\u043F\u0438\u043E\u043D.
      \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0442\u044B \u043F\u043E\u0440\u0432\u0430\u043B
      \u0442\u0440\u0430\u0441\u0441\u0443\r\n\u0432\u0441\u0435 \u0431\u0430\u0431\u043A\u0438
      \u0442\u0432\u043E\u0438. \u043F\u043B\u044E\u0441 \u0431\u043E\u043D\u0443\u0441
      \u043E\u0442 \u043C\u0435\u043D\u044F \u2014 100 \u0440\u0443\u0431"
    delayAfter: 4
  - sender: 1
    text: "\u0438 \u043E\u0442 \u043C\u0435\u043D\u044F \u2014 \u0441\u043A\u0438\u0434\u043A\u0430
      \u043D\u0430 \u043B\u044E\u0431\u0443\u044E \u043A\u0440\u043E\u0448\u043A\u0443
      50%\r\n\u0442\u0430\u043A\u043E\u0433\u043E \u0443 \u043C\u0435\u043D\u044F
      \u0434\u0430\u0436\u0435 \u0431\u043E\u0441\u0441 \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0430\u043B"
    delayAfter: 0
  - sender: 0
    text: "\u0445\u0438\u043C\u0438\u043A, \u0442\u044B \u043C\u0435\u043D\u044F
      \u043A\u043E\u0433\u0434\u0430-\u043D\u0438\u0431\u0443\u0434\u044C \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u0448\u044C
      \u043F\u043E\u0437\u043E\u0440\u0438\u0442\u044C?"
    delayAfter: 0
  - sender: 1
    text: "\u043A\u043E\u0433\u0434\u0430 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u0435\u0448\u044C
      \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0432\u0430\u0442\u044C \u043C\u043D\u0435
      \u0432 \u043A\u0430\u0440\u0442\u044B"
    delayAfter: 0
  - sender: 2
    text: "\u044F \u0432\u0438\u0434\u0435\u043B \u0442\u043E\u0442 \u0437\u0430\u0431\u0435\u0433\r\n\u044D\u0442\u043E
      \u0431\u044B\u043B \u043D\u0435 \u0442\u0430\u0440\u0430\u043A\u0430\u043D\r\n\u044D\u0442\u043E
      \u0431\u044B\u043B\u0430 \u043C\u043E\u043B\u043D\u0438\u044F"
    delayAfter: 0
  - sender: 0
    text: "\u043C\u043E\u043B\u0447\u0443\u043D \u0441\u043A\u0430\u0437\u0430\u043B
      \u043A\u043E\u043C\u043F\u043B\u0438\u043C\u0435\u043D\u0442. \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u0442\u0435
      \u044D\u0442\u043E\u0442 \u0434\u0435\u043D\u044C"
    delayAfter: 2
  - sender: 1
    text: "\u0441\u043A\u0440\u0438\u043D"
    delayAfter: 2
  - sender: 2
    text: "\u0443\u0434\u0430\u043B\u0438"
    delayAfter: 2
  - sender: 0
    text: "\u043D\u0435 \u0443\u0434\u0430\u043B\u0438\u0442\r\n\u043B\u0430\u0434\u043D\u043E,
      \u0447\u0435\u043C\u043F\u0438\u043E\u043D. \u043E\u0442\u0434\u044B\u0445\u0430\u0439.
      \u0437\u0430\u0432\u0442\u0440\u0430 \u043D\u043E\u0432\u044B\u0439 \u0437\u0430\u0431\u0435\u0433"
    delayAfter: 0
  - sender: 0
    text: "\u0438 \u0437\u0430\u0445\u043E\u0434\u0438 \u0437\u0430 \u0441\u043A\u0438\u0434\u043A\u043E\u0439
      \u0440\u0435\u0430\u043B\u044C\u043D\u043E 50%"
    delayAfter: 0
