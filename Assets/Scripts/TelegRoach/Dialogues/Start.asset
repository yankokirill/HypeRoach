--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bd89ac3767350f0468390e0322785532, type: 3}
  m_Name: Start
  m_EditorClassIdentifier: 
  messages:
  - sender: 0
    text: "\u0442\u0430\u043A, \u043D\u043E\u0432\u0435\u043D\u044C\u043A\u0438\u0439,
      \u0441\u043B\u0443\u0448\u0430\u0439 \u0441\u044E\u0434\u0430\r\n\u0442\u044B
      \u0442\u043E\u0442 \u0441\u0430\u043C\u044B\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u043A\u0440\u043E\u0448\u043A\u0438 \u043F\u043E\u0434 \u043A\u0440\u043E\u0432\u0430\u0442\u044C
      \u0440\u0430\u0441\u0441\u044B\u043F\u0430\u043B?\r\n\u0434\u0443\u043C\u0430\u043B,
      \u0442\u0430\u0440\u0430\u043A\u0430\u043D\u043E\u0432 \u0440\u0430\u0437\u0432\u043E\u0434\u0438\u0442\u044C
      \u0431\u0443\u0434\u0435\u0448\u044C?"
    delayAfter: 4
  - sender: 1
    text: "\u043C\u044B \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0438\r\n\u0443
      \u043D\u0435\u0433\u043E \u0443\u0436\u0435 \u0448\u0442\u0443\u043A \u043F\u044F\u0442\u044C
      \u0431\u0435\u0433\u0430\u0435\u0442"
    delayAfter: 4
  - sender: 2
    text: "\u0448\u0435\u0441\u0442\u044C"
    delayAfter: 2
  - sender: 0
    text: "\u043C\u043E\u043B\u0447\u0443\u043D, \u0442\u044B \u0438\u0445 \u043F\u0435\u0440\u0435\u0441\u0447\u0438\u0442\u0430\u043B?\r\n\u043B\u0430\u0434\u043D\u043E,
      \u043D\u0435\u0432\u0430\u0436\u043D\u043E\r\n\u0441\u043B\u0443\u0448\u0430\u0439,
      \u043F\u0435\u0440\u0432\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A, \u0443
      \u043D\u0430\u0441 \u0442\u0443\u0442 \u0441\u0432\u043E\u0438 \u043F\u043E\u0440\u044F\u0434\u043A\u0438"
    delayAfter: 5
  - sender: 1
    text: "\u0442\u044B \u043D\u0435 \u043F\u0435\u0440\u0432\u044B\u0439, \u043A\u0442\u043E
      \u0445\u043E\u0447\u0435\u0442 \u0440\u0430\u0437\u0431\u043E\u0433\u0430\u0442\u0435\u0442\u044C
      \u043D\u0430 \u0442\u0430\u0440\u0430\u043A\u0430\u043D\u0430\u0445\r\n\u0434\u043E
      \u0442\u0435\u0431\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u043F\u044F\u0442\u044C
      \u043F\u044B\u0442\u0430\u043B\u043E\u0441\u044C"
    delayAfter: 4
  - sender: 2
    text: "\u0442\u0440\u043E\u0435 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
      \u0432 \u043E\u0431\u0449\u0430\u0433\u0435 \u0436\u0438\u0432\u0443\u0442"
    delayAfter: 4
  - sender: 0
    text: "\u0434\u0432\u043E\u0435 \u2014 \u043D\u0435\u0442"
    delayAfter: 2
  - sender: 1
    text: "\u0431\u043E\u0441\u0441, \u043D\u0435 \u043F\u0443\u0433\u0430\u0439
      \u043F\u0430\u0446\u0430\u043D\u0430"
    delayAfter: 2
  - sender: 0
    text: "\u044F \u043D\u0435 \u043F\u0443\u0433\u0430\u044E\r\n\u043E\u0431\u044A\u044F\u0441\u043D\u044F\u044E
      \u043A\u0430\u043A \u0435\u0441\u0442\u044C\r\n\u0445\u043E\u0447\u0435\u0448\u044C
      \u0440\u0430\u0437\u0432\u043E\u0434\u0438\u0442\u044C \u2014 \u0431\u0443\u0434\u044C
      \u0434\u043E\u0431\u0440, \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u0439
      \u0432 \u043E\u0431\u0449\u0435\u043C \u0434\u0435\u043B\u0435"
    delayAfter: 5
  - sender: 1
    text: "\u043A\u0430\u0436\u0434\u044B\u0439 \u0432\u0435\u0447\u0435\u0440 \u2014
      \u0433\u043E\u043D\u043A\u0438\r\n\u0442\u0430\u0440\u0430\u043A\u0430\u043D\u044B
      \u0431\u0435\u0433\u0430\u044E\u0442, \u043B\u044E\u0434\u0438 \u0441\u0442\u0430\u0432\u044F\u0442\r\n\u043C\u044B
      \u0442\u0443\u0442 \u0442\u0438\u043F\u0430 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u044B"
    delayAfter: 5
  - sender: 2
    text: "\u0442\u0438\u043F\u0430"
    delayAfter: 2
  - sender: 0
    text: "\u043C\u043E\u043B\u0447\u0443\u043D, \u043D\u0435 \u0443\u043C\u043D\u0438\u0447\u0430\u0439\r\n\u043A\u043E\u0440\u043E\u0447\u0435,
      \u043D\u043E\u0432\u0435\u043D\u044C\u043A\u0438\u0439\r\n\u0443 \u0442\u0435\u0431\u044F
      \u0435\u0441\u0442\u044C \u0447\u0435\u043C\u043F\u0438\u043E\u043D?"
    delayAfter: 4
  - sender: 3
    text: "\u0410 \u044D\u0442\u043E \u043A\u0442\u043E?"
    delayAfter: 3
  - sender: 1
    text: "\u043D\u0443, \u0442\u043E\u0442 \u0442\u0430\u0440\u0430\u043A\u0430\u043D,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443 \u0442\u0435\u0431\u044F
      \u0441\u0430\u043C\u044B\u0439 \u0431\u044B\u0441\u0442\u0440\u044B\u0439"
    delayAfter: 4
  - sender: 0
    text: "\u0435\u0441\u043B\u0438 \u0435\u0433\u043E \u043D\u0435\u0442 \u2014
      \u043C\u044B \u043F\u043E\u043C\u043E\u0436\u0435\u043C \u0432\u044B\u0431\u0440\u0430\u0442\u044C\r\n\u043D\u043E
      \u0433\u043E\u043D\u044F\u0442\u044C \u043F\u0440\u0438\u0434\u0451\u0442\u0441\u044F\r\n\u043A\u0430\u0436\u0434\u044B\u0439
      \u0434\u0435\u043D\u044C\r\n\u043F\u043E\u043D\u044F\u043B?"
    delayAfter: 5
  - sender: 1
    text: "\u0438\u043D\u0430\u0447\u0435 \u043D\u0438\u043A\u0430\u043A\r\n\u044D\u0442\u043E
      \u043D\u0435 \u043D\u0430\u0448 \u043A\u0430\u043F\u0440\u0438\u0437, \u044D\u0442\u043E
      \u0441\u0438\u0441\u0442\u0435\u043C\u0430\r\n\u0441\u0442\u0430\u0440\u0448\u0430\u043A\u0438
      \u0442\u0430\u043A \u0440\u0435\u0448\u0438\u043B\u0438\r\n\u0430 \u0441\u0442\u0430\u0440\u0448\u0430\u043A\u0438
      \u2014 \u044D\u0442\u043E \u043C\u044B"
    delayAfter: 5
  - sender: 0
    text: "\u0438 \u043D\u0435 \u043F\u043E\u043F\u0430\u0434\u0430\u0442\u044C\u0441\u044F
      \u043A\u043E\u043C\u0435\u043D\u0434\u0430\u043D\u0442\u0448\u0435\r\n\u0435\u0441\u043B\u0438
      \u0443\u0437\u043D\u0430\u0435\u0442 \u2014 \u0434\u0435\u0437\u0438\u043D\u0441\u0435\u043A\u0446\u0438\u044F\r\n\u0442\u043E\u0433\u0434\u0430
      \u0432\u0441\u0451, \u043F\u0440\u0438\u0435\u0445\u0430\u043B\u0438"
    delayAfter: 5
  - sender: 2
    text: "\u0431\u044B\u043B\u043E \u0443\u0436\u0435"
    delayAfter: 2
  - sender: 0
    text: "\u0431\u044B\u043B\u043E, \u043D\u043E \u043C\u044B \u0432\u044B\u0436\u0438\u043B\u0438\r\n\u0442\u044B,
      \u043A\u0441\u0442\u0430\u0442\u0438, \u0442\u043E\u0436\u0435 \u0432\u044B\u0436\u0438\u0432\u0435\u0448\u044C,
      \u0435\u0441\u043B\u0438 \u0431\u0443\u0434\u0435\u0448\u044C \u0441\u043B\u0443\u0448\u0430\u0442\u044C"
    delayAfter: 4
  - sender: 1
    text: "\u0432 \u043E\u0431\u0449\u0435\u043C, \u0434\u043E\u0431\u0440\u043E
      \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u0432 \u0431\u0440\u0438\u0433\u0430\u0434\u0443\r\n\u0432\u043E\u043F\u0440\u043E\u0441\u044B
      \u0431\u0443\u0434\u0443\u0442 \u2014 \u043F\u0438\u0448\u0438 \u0441\u044E\u0434\u0430"
    delayAfter: 4
  - sender: 2
    text: "\u043D\u043E \u043B\u0443\u0447\u0448\u0435 \u043D\u0435 \u043F\u0438\u0448\u0438"
    delayAfter: 0
  - sender: 0
    text: "\u043C\u043E\u043B\u0447\u0443\u043D, \u0438\u0434\u0438 \u0443\u0436\u0435\r\n\u043A\u043E\u0440\u043E\u0447\u0435,
      \u043D\u043E\u0432\u0435\u043D\u044C\u043A\u0438\u0439\r\n\u0437\u0430\u0432\u0442\u0440\u0430
      \u043F\u0435\u0440\u0432\u044B\u0439 \u0437\u0430\u0431\u0435\u0433\r\n\u0433\u043E\u0442\u043E\u0432\u044C\u0441\u044F,
      \u0432\u043E\u0442 \u0430\u0432\u0430\u043D\u0441"
    delayAfter: 0
