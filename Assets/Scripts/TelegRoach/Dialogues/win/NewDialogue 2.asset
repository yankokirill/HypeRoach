  - sender: 1
    text: "\u0441\u0442\u0430\u0432\u043A\u0438 \u0431\u044B\u043B\u0438 3 \u043A
      1 \u043D\u0435 \u0432 \u043D\u0430\u0448\u0443 \u043F\u043E\u043B\u044C\u0437\u0443\r\n\u044F,
      \u043A\u0441\u0442\u0430\u0442\u0438, \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B
      \u043D\u0430 \u0442\u0435\u0431\u044F"
