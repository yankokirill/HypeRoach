  messages:
  - sender: 0
    text: "\u044D\u0442\u043E\u0442 \u0434\u043E\u0445\u043B\u044B\u0439 \u0431\u044B\u043B
      \u0431\u044B\u0441\u0442\u0440\u0435\u0435, \u0447\u0435\u043C \u044F \u0434\u0443\u043C\u0430\u043B\r\n\u043D\u043E
      \u0442\u044B \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u043B"
