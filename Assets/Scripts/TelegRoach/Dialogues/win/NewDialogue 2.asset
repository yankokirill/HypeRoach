  - sender: 2
    text: "\u044F \u0442\u043E\u0436\u0435"
    delayAfter: 0
  - sender: 1
    text: "\u043C\u043E\u043B\u0447\u0443\u043D?\r\n\u0442\u044B \u0432\u043E\u043E\u0431\u0449\u0435
      \u0441\u0442\u0430\u0432\u0438\u0448\u044C?"
