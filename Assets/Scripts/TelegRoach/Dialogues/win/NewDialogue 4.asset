  messages:
  - sender: 1
    text: "\u0441\u043B\u0443\u0448\u0430\u0439, \u0430 \u0442\u044B \u043D\u0435
      \u0434\u0443\u043C\u0430\u043B \u0431\u0440\u043E\u0441\u0438\u0442\u044C \u0431\u0435\u0433\u0430?\r\n\u0430
      \u0442\u043E \u0443 \u0434\u0440\u0443\u0433\u0438\u0445 \u0432\u043E\u043E\u0431\u0449\u0435
      \u0448\u0430\u043D\u0441\u043E\u0432 \u043D\u0435\u0442"
    delayAfter: 0
  - sender: 0
    text: "\u0445\u0438\u043C\u0438\u043A, \u043D\u0435 \u0441\u043C\u0443\u0449\u0430\u0439
      \u0447\u0435\u043C\u043F\u0438\u043E\u043D\u0430"
    delayAfter: 0
  - sender: 1
    text: "\u044F \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E\r\n\u044D\u0442\u043E\u0442
      \u0434\u043E\u0445\u043B\u044B\u0439 \u043F\u043E\u0441\u043B\u0435 \u0444\u0438\u043D\u0438\u0448\u0430
      \u0432 \u0443\u0433\u043E\u043B \u0443\u043F\u043E\u043B\u0437 \u0438 \u043F\u043B\u0430\u0447\u0435\u0442"
    delayAfter: 0
  - sender: 2
    text: "\u0432\u0438\u0434\u0435\u043B\r\n\u0436\u0430\u043B\u043A\u043E"
    delayAfter: 0
  - sender: 0
    text: "\u0441\u0430\u043C\u0438 \u0432\u0438\u043D\u043E\u0432\u0430\u0442\u044B\r\n\u043D\u0435\u0447\u0435\u0433\u043E
