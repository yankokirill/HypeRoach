  messages:
  - sender: 0
    text: "\u0433\u0440\u0430\u0446, \u043C\u0430\u043B\u044B\u0448. \u043D\u043E\u0440\u043C
      \u0437\u0430\u0431\u0435\u0433\r\n\u0431\u0435\u0437 \u043D\u0435\u0440\u0432\u043E\u0432,
      \u0431\u0435\u0437 \u043A\u043E\u0441\u044F\u043A\u043E\u0432"
    delayAfter: 0
  - sender: 1
    text: "\u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430\r\n\u044F
      \u0436\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u043B \u2014 \u043A\u0440\u043E\u0448\u043A\u0438
      \u0440\u0435\u0448\u0430\u044E\u0442"
    delayAfter: 1.5
  - sender: 2
    text: (+)
    delayAfter: 0
  - sender: 0
    text: "\u043C\u043E\u043B\u0447\u0443\u043D, \u0442\u044B \u0445\u043E\u0442\u044C
      \u0441\u043B\u043E\u0432\u043E \u0438\u043D\u043E\u0433\u0434\u0430 \u0433\u043E\u0432\u043E\u0440\u0438"
    delayAfter: 0
  - sender: 2
    text: "\u043F\u043E\u0431\u0435\u0434\u0430"
    delayAfter: 0
  - sender: 1
    text: "\u0440\u0430\u0437 \u043D\u0430\u0448 \u0447\u0435\u043C\u043F\u0438\u043E\u043D
      \u043F\u043E\u0431\u0435\u0436\u0434\u0430\u0435\u0442,\n\u043C\u043E\u0436\u0435\u0442,
      \u043F\u043E\u0440\u0430 \u043F\u043E\u0432\u044B\u0448\u0430\u0442\u044C \u0441\u0442\u0430\u0432\u043A\u0438?"
    delayAfter: 0
  - sender: 0
    text: "\u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u043C\r\n\u0447\u0435\u043C\u043F\u0438\u043E\u043D,
