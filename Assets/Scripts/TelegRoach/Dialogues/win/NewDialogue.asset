  m_Script: {fileID: 11500000, guid: bd89ac3767350f0468390e0322785532, type: 3}
  m_Name: NewDialogue
  m_EditorClassIdentifier: 
  messages:
  - sender: 1
    text: "\u0441\u043B\u0443\u0448\u0430\u0439, \u0440\u0435\u0430\u043A\u0446\u0438\u044F
      \u043F\u0440\u043E\u0448\u043B\u0430 \u043A\u0430\u043A \u043D\u0430\u0434\u043E\r\n\u0447\u0438\u0441\u0442\u0430\u044F
      \u0440\u0430\u0431\u043E\u0442\u0430"
    delayAfter: 2
  - sender: 0
    text: "\u0433\u0440\u0430\u0446, \u043C\u0430\u043B\u044B\u0448. \u0441\u0435\u0433\u043E\u0434\u043D\u044F
      \u0442\u044B \u0441\u0438\u044F\u043B\r\n\u043A\u043E\u0440\u0435\u0448\u0430
      \u0433\u043E\u0432\u043E\u0440\u044F\u0442, \u0442\u0430\u043A\u043E\u0433\u043E
      \u0434\u0430\u0432\u043D\u043E \u043D\u0435 \u0432\u0438\u0434\u0435\u043B\u0438"
    delayAfter: 0
  - sender: 1
    text: "\u044F, \u043A\u0441\u0442\u0430\u0442\u0438, \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B
      \u043D\u0430 \u0442\u0435\u0431\u044F 200 \u0440\u0443\u0431\u043B\u0435\u0439\r\n\u0432\u044B\u0438\u0433\u0440\u0430\u043B
      400. \u0441\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043F\u0440\u043E\u0444\u0438\u0442"
    delayAfter: 0
  - sender: 0
    text: "\u0445\u0438\u043C\u0438\u043A, \u043D\u0435 \u043F\u043E\u0437\u043E\u0440\u044C\u0441\u044F.
      \u043A\u0430\u043A\u0438\u0435 \u0441\u0442\u0430\u0432\u043A\u0438, \u043A\u043E\u0433\u0434\u0430
      \u043D\u0430\u0448 \u0447\u0435\u043C\u043F\u0438\u043E\u043D \u0431\u0435\u0436\u0438\u0442?"
    delayAfter: 0
  - sender: 1
    text: "\u0434\u0435\u043B\u043E\u0432\u043E\u0439 \u043F\u043E\u0434\u0445\u043E\u0434,
      \u0431\u043E\u0441\u0441. \u043D\u0438\u0447\u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0433\u043E"
    delayAfter: 0
  - sender: 2
    text: "\u044F \u0442\u043E\u0436\u0435 \u0441\u0442\u0430\u0432\u0438\u043B"
    delayAfter: 2
  - sender: 2
    text: "\u043D\u0430 \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430"
    delayAfter: 1.5
  - sender: 0
    text: ...
    delayAfter: 0.5
  - sender: 1
    text: \U0001F923
    delayAfter: 2
  - sender: 2
    text: "\u0448\u0443\u0442\u043A\u0430"
    delayAfter: 2
  - sender: 0
    text: "\u043C\u043E\u043B\u0447\u0443\u043D, \u043A\u0440\u0430\u0441\u0430\u0432\u0430!"
    delayAfter: 2
  - sender: 2
    text: "\u043D\u0435\u0442"
    delayAfter: 0
