  messages:
  - sender: 0
    text: "\u0445\u043E\u0440\u043E\u0448\u0438\u0439 \u0437\u0430\u0431\u0435\u0433\r\n\u044F
      \u0432 \u0442\u0435\u0431\u044F \u0432\u0435\u0440\u0438\u043B \u0441 \u0441\u0430\u043C\u043E\u0433\u043E
      \u043D\u0430\u0447\u0430\u043B\u0430"
    delayAfter: 0
  - sender: 1
    text: "\u0432\u0440\u0430\u0442\u044C \u043D\u0435\u0445\u043E\u0440\u043E\u0448\u043E,
      \u0431\u043E\u0441\u0441\r\n\u044F \u0432\u0438\u0434\u0435\u043B \u0442\u0432\u043E\u0451
      \u043B\u0438\u0446\u043E \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u043C
      \u043A\u0440\u0443\u0433\u0435"
    delayAfter: 0
  - sender: 0
    text: "\u0447\u0442\u043E \u0442\u044B \u0432\u0438\u0434\u0435\u043B?"
    delayAfter: 2
  - sender: 1
    text: "\u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0435"
    delayAfter: 2
  - sender: 0
    text: "\u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u0442\u0430\u043A\u0442\u0438\u043A\u0430"
    delayAfter: 2
  - sender: 1
    text: "\u0442\u0430\u043A\u0442\u0438\u043A\u0430 \u0441\u043E\u043C\u043D\u0435\u0432\u0430\u0442\u044C\u0441\u044F?"
    delayAfter: 2
  - sender: 2
    text: "\u0445\u0432\u0430\u0442\u0438\u0442"
    delayAfter: 1
  - sender: 0
    text: "\u0427\u0442\u043E?"
