  - sender: 2
    text: "\u0441\u043F\u043E\u0440\u0438\u0442\u044C"
    delayAfter: 1
  - sender: 2
    text: "\u043F\u043E\u0431\u0435\u0434\u0430 \u0435\u0441\u0442\u044C\r\n\u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435
      \u043D\u0435\u0432\u0430\u0436\u043D\u043E"
    delayAfter: 0
  - sender: 1
    text: "\u043C\u043E\u043B\u0447\u0443\u043D \u0441\u0435\u0433\u043E\u0434\u043D\u044F
      \u0440\u0430\u0437\u0443\u043C\u043D\u044B\u0439"
    delayAfter: 2
  - sender: 0
    text: "\u043B\u0430\u0434\u043D\u043E, \u043F\u0440\u0438\u043D\u044F\u043B\r\n\u0447\u0435\u043C\u043F\u0438\u043E\u043D,
